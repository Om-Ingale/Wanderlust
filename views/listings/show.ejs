<% layout('/layouts/boilerplate') %>
<script>
  const mapToken = "<%=process.env.MAP_TOKEN%>";
  const listing = <%- JSON.stringify(listing) %>;
</script>
<div class="row mt-3">
  <div class="col-8 offset-2">
    <h3><%= listing.title %></h3>
  </div>
  <div class="card col-8 offset-2 listing-card">
    <img
      src="<%=listing.image.url%>"
      class="card-img-top show-image mt-1"
      alt="listing image"
    />
    <div class="card-body">
      <p class="card-text">
        <p>Owner - <b><%= listing.owner.username%></b></p>
        <%= listing.description %> <br />
        &#8377; <%= listing.price.toLocaleString("en-IN") %> <br />
        <%= listing.location %> <br />
        <%= listing.country %> <br />
      </p>
    </div>
  </div>
</div>
<div class="btns offset-2">
  <%if(currUser && currUser._id.equals(listing.owner._id)){%>
  <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark show-btn"
    >Edit</a
  >&nbsp;&nbsp;<%}%>
  <a href="/listings" class="btn btn-dark show-btn">Back</a>
</div>
<br />
<%if(currUser && currUser._id.equals(listing.owner._id)){%>
<form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
  <button class="btn btn-dark col-1 offset-2 del-btn">Delete</button>
</form>
<%}%>
<br />
<hr />
<div class="row mt-4">
  <div class="col-8 offset-2">
    <h4>Leave a Review</h4>
    <form
      action="/listings/<%=listing._id%>/reviews"
      method="Post"
      class="needs-validation"
      novalidate
    >
      <div class="mt-3">
        <fieldset class="starability-slot">
          <input
            type="radio"
            id="no-rate"
            class="input-no-rate"
            name="review[rating]"
            value="1"
            checked
            aria-label="No rating."
          />
          <input
            type="radio"
            id="first-rate1"
            name="review[rating]"
            value="1"
          />
          <label for="first-rate1" title="Terrible">1 star</label>
          <input
            type="radio"
            id="first-rate2"
            name="review[rating]"
            value="2"
          />
          <label for="first-rate2" title="Not good">2 stars</label>
          <input
            type="radio"
            id="first-rate3"
            name="review[rating]"
            value="3"
          />
          <label for="first-rate3" title="Average">3 stars</label>
          <input
            type="radio"
            id="first-rate4"
            name="review[rating]"
            value="4"
          />
          <label for="first-rate4" title="Very good">4 stars</label>
          <input
            type="radio"
            id="first-rate5"
            name="review[rating]"
            value="5"
          />
          <label for="first-rate5" title="Amazing">5 stars</label>
        </fieldset>
      </div>
      <div>
        <label for="comment" class="form-label">Comment</label>
        <textarea
          name="review[comment]"
          id="comment"
          class="form-control"
          rows="4"
          cols="30"
          required
        ></textarea>
        <div class="invalid-feedback">Please enter Review</div>
      </div>
      <button class="btn btn-outline-dark mt-3 mb-3" type="submit">
        Submit
      </button>
    </form>
  </div>
</div>

<hr />

<div>
  <%if(listing.reviews.length>0){%>
  <div class="row offset-1">
    <h4><b>All Reviews</b></h4>
    <%for(review of listing.reviews){ %>
    <div class="card col-5 mt-3 mb-3 ms-3">
      <div class="card-body">
        <h5 class="card-title mt-3"><%=review.author.username%></h5>
        <p class="starability-result" data-rating="<%=review.rating%>"></p>
        <div class="card-text"><%=review.comment%></div>
        <br />
      </div>
      <%if(currUser && currUser._id.equals(review.author._id)){%>
      <form
        method="POST"
        action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE"
      >
        <button class="btn btn-sm btn-dark mt-3 mb-3">Delete</button>
      </form>
      <%}%>
    </div>
    <%}%>
  </div>
  <%}%>
</div>

<hr>

<div class="row col-6 offset-3 mt-3 mb-3 mt-3">
    <h3 class="mb-2">Where you'll be</h3>
    <div id="map"></div>
</div>

<script src="/js/map.js"></script>